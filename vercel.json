{
  "name": "crushcar",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx next build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "crons": [
    { "path": "/api/jobs/transition", "schedule": "* * * * *" },
    { "path": "/api/jobs/verify-pending", "schedule": "*/15 * * * *" },
    { "path": "/api/jobs/reminders", "schedule": "0 * * * *" }
  ]
}